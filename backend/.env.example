# RoadMuse backend configuration (all variables are optional; defaults shown).
# Copy to .env and adjust as needed.

ROADMUSE_APP_NAME="RoadMuse Backend"
ROADMUSE_APP_VERSION=0.1.0
ROADMUSE_ENVIRONMENT=development
# JSON array of allowed CORS origins.
ROADMUSE_CORS_ORIGINS=["http://localhost:5173"]

# Model used by the RouteIntentAgent, in Pydantic AI "provider:model" form.
# Examples: anthropic:claude-opus-4-8, openai:gpt-5, google-gla:gemini-2.5-pro.
ROADMUSE_ROUTE_AGENT_MODEL=anthropic:claude-opus-4-8
# API key for the chosen provider (read directly by Pydantic AI, so no
# ROADMUSE_ prefix). Set the one matching ROADMUSE_ROUTE_AGENT_MODEL.
# Required for POST /api/route/plan.
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# Host/port are launch-time concerns, not application settings. Set them as
# shell env vars to override `make run-backend` defaults, e.g.:
#   ROADMUSE_HOST=0.0.0.0 ROADMUSE_PORT=9000 make run-backend

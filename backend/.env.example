# RoadMuse backend configuration (all variables are optional; defaults shown).
# Copy to .env and adjust as needed.

ROADMUSE_APP_NAME="RoadMuse Backend"
ROADMUSE_APP_VERSION=0.1.0
ROADMUSE_ENVIRONMENT=development
# JSON array of allowed CORS origins.
ROADMUSE_CORS_ORIGINS=["http://localhost:5173"]

# Host/port are launch-time concerns, not application settings. Set them as
# shell env vars to override `make run-backend` defaults, e.g.:
#   ROADMUSE_HOST=0.0.0.0 ROADMUSE_PORT=9000 make run-backend
